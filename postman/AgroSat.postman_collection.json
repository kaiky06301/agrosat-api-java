{
  "info": {
    "name": "AgroSat API - Global Solution FIAP 2026/1",
    "description": "Coleção de testes da API Java (Spring Boot) do projeto AgroSat. Faça o login primeiro: o token JWT é salvo automaticamente na variável {{token}} e usado nas demais requisições.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://agrosat-api-566067.azurewebsites.net" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth - Login (salva o token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var json = pm.response.json();",
              "if (json.token) { pm.collectionVariables.set('token', json.token); }",
              "pm.test('login retornou token', function () { pm.expect(json.token).to.be.a('string'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@agrosat.com.br\",\n  \"senha\": \"123456\"\n}" }
      }
    },
    {
      "name": "2. Propriedades - Criar (POST)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/propriedades", "host": ["{{baseUrl}}"], "path": ["api", "propriedades"] },
        "body": { "mode": "raw", "raw": "{\n  \"idUsuario\": 1,\n  \"nome\": \"Fazenda Boa Vista\",\n  \"municipio\": \"Ribeirao Preto\",\n  \"uf\": \"SP\",\n  \"areaTotalHa\": 120.5\n}" }
      }
    },
    {
      "name": "3. Propriedades - Listar (GET, com HATEOAS)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/propriedades", "host": ["{{baseUrl}}"], "path": ["api", "propriedades"] }
      }
    },
    {
      "name": "4. Propriedades - Buscar por id (GET)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/propriedades/1", "host": ["{{baseUrl}}"], "path": ["api", "propriedades", "1"] }
      }
    },
    {
      "name": "5. Propriedades - Atualizar (PUT)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/propriedades/1", "host": ["{{baseUrl}}"], "path": ["api", "propriedades", "1"] },
        "body": { "mode": "raw", "raw": "{\n  \"idUsuario\": 1,\n  \"nome\": \"Fazenda Boa Vista (editada)\",\n  \"areaTotalHa\": 99.9\n}" }
      }
    },
    {
      "name": "6. Propriedades - Excluir (DELETE)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/propriedades/1", "host": ["{{baseUrl}}"], "path": ["api", "propriedades", "1"] }
      }
    },
    {
      "name": "7. Validacao - Criar invalido (espera 400)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/propriedades", "host": ["{{baseUrl}}"], "path": ["api", "propriedades"] },
        "body": { "mode": "raw", "raw": "{\n  \"idUsuario\": 1\n}" }
      }
    },
    {
      "name": "8. Equipamentos - Listar (herança/embedded)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/equipamentos", "host": ["{{baseUrl}}"], "path": ["api", "equipamentos"] }
      }
    },
    {
      "name": "9. Talhoes - Listar (GET, com HATEOAS)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/talhoes", "host": ["{{baseUrl}}"], "path": ["api", "talhoes"] }
      }
    }
  ]
}
